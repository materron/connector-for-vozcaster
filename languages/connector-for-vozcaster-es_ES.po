#. Description of the plugin
#: connector-for-vozcaster.php
msgid ""
"Connect your WordPress to the VozCaster Telegram bot — publish podcast "
"episodes from voice notes directly into PowerPress."
msgstr ""

#. Author of the plugin
#: connector-for-vozcaster.php
msgid "Miguel Ángel Terrón Bote"
msgstr ""

#. Author URI of the plugin
#: connector-for-vozcaster.php
msgid "https://potencia.pro"
msgstr ""

#: includes/class-api.php:1232
msgid "No file received."
msgstr "No se ha recibido ningún archivo."

#. translators: %s: the rejected MIME content type.
#: includes/class-api.php:1269
#, php-format
msgid "File type not allowed: %s"
msgstr "Tipo de archivo no permitido: %s"

#: includes/class-auth.php:128
msgid "Invalid parameters."
msgstr "Parámetros inválidos."

#: includes/class-auth.php:129
msgid "Error"
msgstr "Error"

#: includes/class-auth.php:168
msgid "Link expired"
msgstr "Enlace caducado"

#: includes/class-auth.php:169
msgid "This authorization link has expired (10 minutes)."
msgstr "El enlace de autorización ha caducado (10 minutos)."

#. translators: %s: the /conectar bot command, wrapped in a <code> tag.
#: includes/class-auth.php:172
#, php-format
msgid "Go back to the bot and use %s again."
msgstr "Vuelve al bot y usa %s de nuevo."

#: includes/class-auth.php:178
msgid "VozCaster — Link expired"
msgstr "VozCaster — Enlace caducado"

#: includes/class-auth.php:185
msgid "Not authorized"
msgstr "No autorizado"

#. translators: %s: the WordPress username, wrapped in a <strong> tag.
#: includes/class-auth.php:188
#, php-format
msgid "The user %s is not on the list of allowed users."
msgstr "El usuario %s no está en la lista de usuarios permitidos."

#. translators: %s: the plugin settings location, wrapped in an <em> tag.
#: includes/class-auth.php:193
#, php-format
msgid "Ask the administrator to enable you under %s."
msgstr "Pide al administrador que te active en %s."

#: includes/class-auth.php:194
msgid "Settings → VozCaster"
msgstr "Ajustes → VozCaster"

#: includes/class-auth.php:199
msgid "VozCaster — Not authorized"
msgstr "VozCaster — No autorizado"

#: includes/class-auth.php:219
msgid "Connected!"
msgstr "¡Conectado!"

#. translators: %s: the user's display name, wrapped in a <strong> tag.
#: includes/class-auth.php:222
#, php-format
msgid "Hello, %s."
msgstr "Hola, %s."

#: includes/class-auth.php:225
msgid "You can now go back to the Telegram bot and continue."
msgstr "Ya puedes volver al bot de Telegram y continuar."

#: includes/class-auth.php:229
msgid "VozCaster — Connection completed"
msgstr "VozCaster — Conexión completada"

#: includes/class-auth.php:250
msgid "Back to the Telegram bot"
msgstr "Volver al bot de Telegram"

#: includes/class-settings.php:23 includes/class-settings.php:24
#: includes/class-settings.php:335
msgid "VozCaster"
msgstr "VozCaster"

#: includes/class-settings.php:138
msgid "No file selected."
msgstr "No se ha seleccionado ningún archivo."

#: includes/class-settings.php:234
msgid "Invalid attachment."
msgstr "Adjunto no válido."

#: includes/class-settings.php:264
msgid "Podcast permissions updated."
msgstr "Permisos del podcast actualizados."

#: includes/class-settings.php:265
msgid "User list updated."
msgstr "Lista de usuarios actualizada."

#: includes/class-settings.php:266
msgid "User access revoked. They will need to reconnect using /connect."
msgstr "Acceso del usuario revocado. Tendrá que reconectarse con /connect."

#: includes/class-settings.php:267
msgid "Intro file deleted."
msgstr "Archivo de intro borrado."

#: includes/class-settings.php:268
msgid "Outro file deleted."
msgstr "Archivo de outro borrado."

#: includes/class-settings.php:269
msgid "Intro file uploaded successfully."
msgstr "Archivo de intro subido correctamente."

#: includes/class-settings.php:270
msgid "Outro file uploaded successfully."
msgstr "Archivo de outro subido correctamente."

#: includes/class-settings.php:271
msgid "Error uploading intro file. Please make sure it is a valid audio file."
msgstr ""
"Error al subir el archivo de intro. Asegúrate de que es un archivo de audio "
"válido."

#: includes/class-settings.php:272
msgid "Error uploading outro file. Please make sure it is a valid audio file."
msgstr ""
"Error al subir el archivo de outro. Asegúrate de que es un archivo de audio "
"válido."

#: includes/class-settings.php:273
msgid "Episode history cleared."
msgstr "Historial de episodios borrado."

#: includes/class-settings.php:274
msgid "Mix settings saved."
msgstr "Ajustes de mezcla guardados."

#: includes/class-settings.php:275
msgid "Title settings saved."
msgstr "Ajustes de títulos guardados."

#: includes/class-settings.php:276
msgid "Post footer saved."
msgstr "Pie de post guardado."

#: includes/class-settings.php:338
msgid "PowerPress"
msgstr "PowerPress"

#: includes/class-settings.php:341
msgid "PowerPress is installed and active."
msgstr "PowerPress está instalado y activo."

#: includes/class-settings.php:343
msgid ""
"PowerPress is not installed or not active. Episodes will be created without "
"podcast data."
msgstr ""
"PowerPress no está instalado o no está activo. Los episodios se crearán sin "
"datos de podcast."

#: includes/class-settings.php:350
msgid "Podcast access permissions"
msgstr "Permisos de acceso al podcast"

#: includes/class-settings.php:352
msgid ""
"Define which podcast each user can access from the bot and with what "
"permission level. Users without specific permissions configured here will "
"have access to all podcasts with publish permission (backward compatibility)."
msgstr ""
"Define a qué podcast puede acceder cada usuario desde el bot y con qué nivel "
"de permiso. Los usuarios sin permisos específicos configurados aquí tendrán "
"acceso a todos los podcasts con permiso de publicación (compatibilidad hacia "
"atrás)."

#: includes/class-settings.php:356
msgid ""
"Only one podcast is configured. Add more feeds in PowerPress to enable per-"
"podcast permissions."
msgstr ""
"Solo hay un podcast configurado. Añade más feeds en PowerPress para "
"habilitar los permisos por podcast."

#: includes/class-settings.php:364
msgid "User"
msgstr "Usuario"

#: includes/class-settings.php:384
msgid "No access"
msgstr "Sin acceso"

#: includes/class-settings.php:385
msgid "Draft"
msgstr "Borrador"

#: includes/class-settings.php:386
msgid "Publish"
msgstr "Publicar"

#: includes/class-settings.php:395
msgid ""
"No access: user will not see this podcast. Draft: can only submit for "
"review. Publish: publishes directly."
msgstr ""
"Sin acceso: el usuario no verá este podcast. Borrador: solo puede enviar "
"para revisión. Publicar: publica directamente."

#: includes/class-settings.php:397
msgid "Save permissions"
msgstr "Guardar permisos"

#: includes/class-settings.php:404
msgid "Users allowed to use the bot"
msgstr "Usuarios autorizados para usar el bot"

#: includes/class-settings.php:406
msgid ""
"Check the WordPress users allowed to publish episodes from the Telegram bot. "
"Checked users will be able to authenticate using their usual WordPress "
"username and password."
msgstr ""
"Marca los usuarios de WordPress autorizados a publicar episodios desde el "
"bot de Telegram. Los marcados podrán autenticarse con su usuario y "
"contraseña habituales de WordPress."

#: includes/class-settings.php:415
msgid "Allowed"
msgstr "Permitido"

#: includes/class-settings.php:416
msgid "Username"
msgstr "Usuario"

#: includes/class-settings.php:417
msgid "Name"
msgstr "Nombre"

#: includes/class-settings.php:418
msgid "Role"
msgstr "Rol"

#: includes/class-settings.php:419
msgid "Bot status"
msgstr "Estado del bot"

#: includes/class-settings.php:443
msgid "Connected"
msgstr "Conectado"

#: includes/class-settings.php:452
msgid "Revoke access? The user will need to reconnect using /connect."
msgstr "¿Revocar acceso? El usuario tendrá que reconectarse con /connect."

#: includes/class-settings.php:453
msgid "Revoke"
msgstr "Revocar"

#: includes/class-settings.php:456
msgid "Not connected"
msgstr "No conectado"

#: includes/class-settings.php:464
msgid "Save changes"
msgstr "Guardar cambios"

#: includes/class-settings.php:470
msgid "Episode titles"
msgstr "Títulos de los episodios"

#: includes/class-settings.php:472
msgid ""
"Define the prefix prepended to the number and title of each episode. Can "
"also be changed from the Telegram bot with /settings."
msgstr ""
"Define el prefijo que se añade delante del número y el título de cada "
"episodio. También se puede cambiar desde el bot de Telegram con /settings."

#: includes/class-settings.php:481
msgid "Title prefix"
msgstr "Prefijo del título"

#: includes/class-settings.php:487
msgid "E.g.: Chapter, Episode, Ep."
msgstr "Ej.: Capítulo, Episodio, Ep."

#: includes/class-settings.php:491
msgid ""
"Empty = no prefix. With prefix and no season: «Chapter 15: Title». With "
"season: «Chapter T2E15: Title»."
msgstr ""
"Vacío = sin prefijo. Con prefijo y sin temporada: «Capítulo 15: Título». Con "
"temporada: «Capítulo T2E15: Título»."

#: includes/class-settings.php:496
msgid "Include season number"
msgstr "Incluir número de temporada"

#: includes/class-settings.php:503
msgid "Include T2E15 in the title (if a prefix is defined)"
msgstr "Incluir T2E15 en el título (si hay un prefijo definido)"

#: includes/class-settings.php:509
msgid "Chapter numbering in title"
msgstr "Numeración del capítulo en el título"

#: includes/class-settings.php:516
msgid "Chapter within the season (resets at T1, T2…)"
msgstr "Capítulo dentro de la temporada (se reinicia en T1, T2…)"

#: includes/class-settings.php:517
msgid "Example: «Chapter 5: Title» even if it is episode 37 overall."
msgstr "Ejemplo: «Capítulo 5: Título» aunque sea el episodio 37 en total."

#: includes/class-settings.php:523
msgid "Global sequential number (inferred from the previous post title)"
msgstr "Número secuencial global (inferido del título del post anterior)"

#: includes/class-settings.php:524
msgid ""
"Example: «Chapter 38: Title». PowerPress still uses the chapter within the "
"season internally."
msgstr ""
"Ejemplo: «Capítulo 38: Título». PowerPress sigue usando internamente el "
"capítulo dentro de la temporada."

#: includes/class-settings.php:530
msgid "Save title settings"
msgstr "Guardar ajustes de títulos"

#: includes/class-settings.php:536
msgid "Intro &amp; Outro"
msgstr "Intro y outro"

#: includes/class-settings.php:538
msgid ""
"Upload your intro and outro audio files here. They can also be uploaded from "
"the Telegram bot via the Intro/Outro menu."
msgstr ""
"Sube aquí tus archivos de audio de intro y outro. También se pueden subir "
"desde el bot de Telegram en el menú Intro/Outro."

#: includes/class-settings.php:542
msgid "Intro"
msgstr "Intro"

#: includes/class-settings.php:554
msgid "Delete the intro file?"
msgstr "¿Borrar el archivo de intro?"

#: includes/class-settings.php:555 includes/class-settings.php:595
msgid "Delete"
msgstr "Borrar"

#: includes/class-settings.php:559
msgid "To replace the intro, upload a new file:"
msgstr "Para reemplazar la intro, sube un nuevo archivo:"

#: includes/class-settings.php:561
msgid "No intro loaded."
msgstr "No hay intro cargada."

#: includes/class-settings.php:568
msgid "Replace intro"
msgstr "Reemplazar intro"

#: includes/class-settings.php:568
msgid "Upload intro"
msgstr "Subir intro"

#: includes/class-settings.php:577 includes/class-settings.php:617
msgid "Select from media library"
msgstr "Seleccionar de la biblioteca multimedia"

#: includes/class-settings.php:582
msgid "Outro"
msgstr "Outro"

#: includes/class-settings.php:594
msgid "Delete the outro file?"
msgstr "¿Borrar el archivo de outro?"

#: includes/class-settings.php:599
msgid "To replace the outro, upload a new file:"
msgstr "Para reemplazar el outro, sube un nuevo archivo:"

#: includes/class-settings.php:601
msgid "No outro loaded."
msgstr "No hay outro cargado."

#: includes/class-settings.php:608
msgid "Replace outro"
msgstr "Reemplazar outro"

#: includes/class-settings.php:608
msgid "Upload outro"
msgstr "Subir outro"

#: includes/class-settings.php:626
msgid "Audio mix settings (intro/outro)"
msgstr "Ajustes de mezcla de audio (intro/outro)"

#: includes/class-settings.php:628
msgid ""
"Define how intro and outro music is mixed with the podcast audio. These are "
"the default values and can be changed from the Telegram bot."
msgstr ""
"Define cómo se mezclan la intro y el outro con el audio del podcast. Son los "
"valores por defecto y se pueden cambiar desde el bot de Telegram."

#: includes/class-settings.php:637
msgid "Intro duck-in second"
msgstr "Segundo de inicio del duck de la intro"

#: includes/class-settings.php:644 includes/class-settings.php:700
msgid "seconds"
msgstr "segundos"

#: includes/class-settings.php:645
msgid ""
"The intro plays at 100% until this second. From here it starts fading down "
"and the podcast voice fades in."
msgstr ""
"La intro suena al 100% hasta este segundo. A partir de aquí empieza a bajar "
"y la voz del podcast entra en fade-in."

#: includes/class-settings.php:650
msgid "Intro volume under podcast"
msgstr "Volumen de la intro bajo el podcast"

#: includes/class-settings.php:658
msgid ""
"Volume to which the intro fades during duck-in, before reaching 0. Example: "
"30 = intro fades to 30% while the voice comes in."
msgstr ""
"Volumen al que baja la intro durante el duck, antes de llegar a 0. Ejemplo: "
"30 = la intro baja al 30% mientras entra la voz."

#: includes/class-settings.php:663
msgid "Second at which intro reaches 0"
msgstr "Segundo en el que la intro llega a 0"

#: includes/class-settings.php:671
msgid "seconds (empty = until the end of the intro file)"
msgstr "segundos (vacío = hasta el final del archivo de intro)"

#: includes/class-settings.php:672
msgid ""
"Exact second at which the intro reaches silence. If left empty, the fade "
"lasts until the end of the intro file."
msgstr ""
"Segundo exacto en el que la intro llega al silencio. Si se deja vacío, el "
"fade dura hasta el final del archivo de intro."

#: includes/class-settings.php:677
msgid "Knee: seconds to reach duck volume"
msgstr "Rodilla: segundos para llegar al volumen del duck"

#: includes/class-settings.php:685
msgid "seconds after duck start (empty = linear)"
msgstr "segundos después del inicio del duck (vacío = lineal)"

#: includes/class-settings.php:687
msgid ""
"Seconds after the duck start at which the intro has already dropped to the "
"duck volume %. A short value (e.g. 1) gives a sharp initial drop followed by "
"a long gentle tail. The outro uses the exact mirror curve automatically. "
"Leave empty for a linear fade."
msgstr ""
"Segundos después del inicio del duck en los que la intro ya ha bajado al % "
"del duck. Un valor corto (ej. 1) da una caída inicial rápida seguida de una "
"cola larga y suave. El outro usa automáticamente la curva espejo exacta. "
"Déjalo vacío para un fade lineal."

#: includes/class-settings.php:693
msgid "Seconds before end for outro fade-in"
msgstr "Segundos antes del final para el fade-in del outro"

#: includes/class-settings.php:701
msgid ""
"The outro starts playing in the background this many seconds before the "
"podcast voice ends. When the voice ends, it rises to 100%."
msgstr ""
"El outro empieza a sonar en segundo plano estos segundos antes de que "
"termine la voz del podcast. Cuando la voz acaba, sube al 100%."

#: includes/class-settings.php:706
msgid "Outro volume under podcast"
msgstr "Volumen del outro bajo el podcast"

#: includes/class-settings.php:714
msgid ""
"Maximum volume of the outro while the podcast voice is still playing. When "
"the voice ends, the outro rises to 100%."
msgstr ""
"Volumen máximo del outro mientras la voz del podcast sigue sonando. Cuando "
"la voz acaba, el outro sube al 100%."

#: includes/class-settings.php:718
msgid "Save mix settings"
msgstr "Guardar ajustes de mezcla"

#: includes/class-settings.php:724
msgid "Post footer (signature)"
msgstr "Pie de post (firma)"

#: includes/class-settings.php:726
msgid ""
"HTML or Gutenberg block markup appended automatically to every post "
"published by the bot. You can also edit it from the Telegram bot with /firma."
msgstr ""
"Código HTML o de bloques de Gutenberg que se añade automáticamente al final "
"de cada post publicado por el bot. También se puede editar desde el bot de "
"Telegram con /firma."

#: includes/class-settings.php:735
msgid "Footer content"
msgstr "Contenido del pie"

#: includes/class-settings.php:745
msgid ""
"Accepts raw HTML and Gutenberg block comments. Appended verbatim after the "
"episode content. Leave empty to disable."
msgstr ""
"Acepta HTML en bruto y comentarios de bloques de Gutenberg. Se añade tal "
"cual al final del contenido del episodio. Déjalo vacío para desactivarlo."

#: includes/class-settings.php:750
msgid "Save footer"
msgstr "Guardar pie"

#: includes/class-settings.php:756
msgid "Recent published episodes"
msgstr "Episodios publicados recientes"

#: includes/class-settings.php:758
msgid "No episodes have been published with the bot yet."
msgstr "Aún no se ha publicado ningún episodio con el bot."

