msgid "Date"
msgstr "Fecha"

#: includes/class-settings.php:764
msgid "Title"
msgstr "Título"

#: includes/class-settings.php:765
msgid "Author"
msgstr "Autor"

#: includes/class-settings.php:766
msgid "Status"
msgstr "Estado"

#: includes/class-settings.php:767
msgid "Link"
msgstr "Enlace"

#: includes/class-settings.php:779
msgid "View"
msgstr "Ver"

#: includes/class-settings.php:791
msgid "Clear history"
msgstr "Borrar historial"

#: includes/class-settings.php:799
msgid "Select intro audio"
msgstr "Selecciona el audio de intro"

#: includes/class-settings.php:800
msgid "Select outro audio"
msgstr "Selecciona el audio de outro"

#: includes/class-settings.php:804
msgid "Select"
msgstr "Seleccionar"
